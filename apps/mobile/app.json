{
  "expo": {
    "name": "CrewClock",
    "slug": "crewclock",
    "version": "1.0.0",
    "scheme": "crewclock",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": { "image": "./assets/splash.png", "resizeMode": "contain", "backgroundColor": "#2563eb" },
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.crewclock.app", "infoPlist": { "NSLocationWhenInUseUsageDescription": "CrewClock uses your location to verify clock-ins.", "NSLocationAlwaysAndWhenInUseUsageDescription": "CrewClock uses your location in the background for geofenced clock-ins.", "NSFaceIDUsageDescription": "Use Face ID to quickly clock in." } },
    "android": { "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#2563eb" }, "package": "com.crewclock.app", "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION", "USE_BIOMETRIC", "USE_FINGERPRINT", "CAMERA", "RECEIVE_BOOT_COMPLETED"] },
    "plugins": ["expo-router", "expo-location", "expo-notifications", ["expo-local-authentication", { "faceIDPermission": "Use Face ID for quick clock-in" }]],
    "extra": { "eas": { "projectId": "YOUR_EAS_PROJECT_ID" } }
  }
}
