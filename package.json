{
  "name": "crewclock",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "biome format --write .",
    "db:push": "turbo db:push",
    "db:studio": "pnpm --filter @crewclock/db studio",
    "db:generate": "pnpm --filter @crewclock/db generate",
    "db:migrate": "pnpm --filter @crewclock/db migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.14.0"
}
